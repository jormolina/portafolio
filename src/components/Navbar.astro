---

<header class="header">
  <div class="header-inner">
    <div class="header-left">
      <a href="/" class="header-brand">
        <svg height="32" viewBox="0 0 16 16" width="32" fill="#e6edf3">
          <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"></path>
        </svg>
      </a>
      <nav class="header-nav">
        <a href="#proyectos" class="header-link">Proyectos</a>
        <a href="#contacto" class="header-link">Contacto</a>
      </nav>
    </div>
    <div class="header-right">
      <div class="search-bar">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="var(--text-secondary)">
          <path d="M10.68 11.74a6 6 0 0 1-7.922-8.982 6 6 0 0 1 8.982 7.922l3.04 3.04a.749.749 0 0 1-.326 1.275.749.749 0 0 1-.734-.215ZM11.5 7a4.499 4.499 0 1 0-8.997 0A4.499 4.499 0 0 0 11.5 7Z"></path>
        </svg>
        <span class="search-text">Type <kbd>/</kbd> to search</span>
      </div>
    </div>
  </div>
</header>

<style is:global>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 62px;
    background: var(--bg-default);
    border-bottom: 1px solid var(--border-default);
    z-index: 100;
  }

  .header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .header-brand {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .header-brand svg {
    transition: opacity 0.2s;
  }

  .header-brand:hover svg {
    opacity: 0.7;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .header-link {
    padding: 6px 12px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    border-radius: 6px;
    transition: background 0.15s;
    text-decoration: none;
  }

  .header-link:hover {
    background: var(--bg-subtle);
    text-decoration: none;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 12px;
    background: var(--bg-canvas);
    border: 1px solid var(--border-default);
    border-radius: 6px;
    min-width: 280px;
    cursor: pointer;
    transition: border-color 0.15s;
  }

  .search-bar:hover {
    border-color: var(--text-secondary);
  }

  .search-text {
    font-size: 14px;
    color: var(--text-secondary);
  }

  .search-text kbd {
    display: inline-block;
    padding: 0px 6px;
    font-size: 12px;
    font-family: inherit;
    color: var(--text-secondary);
    background: var(--bg-default);
    border: 1px solid var(--border-default);
    border-radius: 3px;
  }

  @media (max-width: 768px) {
    .search-bar {
      display: none;
    }

    .header-inner {
      padding: 0 16px;
    }
  }
</style>
